# Copy to .env.local (gitignored). Local dev works with NO env vars at all —
# the site falls back to an embedded dev database (.pglite/). These are only
# required for production (Vercel → Project → Settings → Environment Variables).

# Postgres connection string — create a free database at https://neon.tech,
# then run `npm run db:push` once to create the tables.
# DATABASE_URL=

# Session signing secret — generate with: openssl rand -base64 32
# BETTER_AUTH_SECRET=

# The site's public URL, e.g. https://thcmedsolutions.com
# BETTER_AUTH_URL=

# AI Plant Doctor — get a key at https://console.anthropic.com
# Without it the Doctor page shows a friendly "waking up" state.
# ANTHROPIC_API_KEY=
# Optional: override the model (default claude-sonnet-5)
# PLANT_DOCTOR_MODEL=

# Medical Card intake form → emails the provider's office (Resend).
# Get a key at https://resend.com, verify your sending domain, then set:
# RESEND_API_KEY=
# Where patient requests are emailed (the provider's inbox):
# MEDICAL_INTAKE_TO=
# From address (must be on a Resend-verified domain in production;
# defaults to onboarding@resend.dev for first-run testing):
# MEDICAL_INTAKE_FROM="THCMed Solutions <appointments@thcmedsolutions.com>"
